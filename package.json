{
  "name": "frag-arena",
  "version": "0.0.1",
  "description": "Frag Arena - browser arena shooter (netcode-first). Forked from timetocode/nengi-babylon-3d-shooter.",
  "private": true,
  "scripts": {
    "start": "npm-run-all --parallel server client",
    "server": "tsx watch server/serverMain.js",
    "server:once": "tsx server/serverMain.js",
    "client": "cross-env NODE_OPTIONS=--openssl-legacy-provider webpack-dev-server --config webpack.dev.js",
    "build": "cross-env NODE_OPTIONS=--openssl-legacy-provider webpack --config webpack.prod.js",
    "verify": "node scripts/verify-netcode.mjs",
    "verify:movement": "node scripts/verify-movement.mjs",
    "verify:mobile": "node scripts/verify-mobile.mjs",
    "postinstall": "patch-package"
  },
  "author": "timetocode // Alex (fork: Frag Arena)",
  "license": "Apache-2.0",
  "dependencies": {
    "babylonjs": "^4.0.3",
    "babylonjs-loaders": "^4.0.3",
    "nengi": "^1.18.0",
    "ws": "^8.21.0",
    "xhr2": "^0.2.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "npm-run-all": "4.1.5",
    "patch-package": "^8.0.1",
    "puppeteer-core": "^25.3.0",
    "terser-webpack-plugin": "^2.3.4",
    "tsx": "^4.23.0",
    "webpack": "4.41.1",
    "webpack-cli": "3.3.9",
    "webpack-dev-server": "3.8.2",
    "webpack-merge": "4.2.2"
  }
}
